# Only common dependencies that are NOT required to run test_integration.sh are
# specified here. Everything else is in test_integration.sh.
require:
    - bats
    - bind-utils
    - bridge-utils
    - cargo
    - clippy
    - dbus-daemon
    - dnsmasq
    - firewalld
    - go-md2man
    - git-core
    - iptables
    - jq
    - make
    - net-tools
    - nftables
    - nmap-ncat
    - protobuf-compiler
    - rustfmt

adjust:
    duration: 10m
    when: arch == aarch64

/validate:
    tag: upstream
    summary: Validate test
    test: make -C ../.. validate

/unit:
    tag: upstream
    summary: Unit test
    test: make -C ../.. unit

/integration:
    tag: [ upstream, downstream ]
    summary: Integration tests
    test: bash test_integration.sh
